                            <a href="/reservar?empresa=Creative Studio" class="btn btn-light mt-3">Reservar</a>

                        </div>

                    </div>

                </div>

                <!-- EMPRESA 2 -->

                <div class="swiper-slide">

                    <div class="company-card">

                        <img src="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?q=80&w=1200">

                        <div class="company-overlay">

                            <img
                            class="logo"
                            src="https://cdn-icons-png.flaticon.com/512/732/732200.png">

                            <h3>Tech Solutions</h3>

                            <p>Soporte técnico digital.</p>

                           <a href="/reservar?empresa=Tech Solutions" class="btn btn-light mt-3">Reservar</a>

                        </div>

                    </div>

                </div>

                <!-- EMPRESA 3 -->

                <div class="swiper-slide">

                    <div class="company-card">

                        <img src="https://images.unsplash.com/photo-1556761175-b413da4baf72?q=80&w=1200">

                        <div class="company-overlay">

                            <img
                            class="logo"
                            src="https://cdn-icons-png.flaticon.com/512/5968/5968672.png">

                            <h3>Business Group</h3>

                            <p>Consultoría empresarial.</p>

                            <a href="/reservar?empresa=Business Group" class="btn btn-light mt-3">Reservar</a>

                        </div>

                    </div>

                </div>

                <!-- EMPRESA 4 -->

                <div class="swiper-slide">

                    <div class="company-card">

                        <img src="https://images.unsplash.com/photo-1521737604893-d14cc237f11d?q=80&w=1200">

                        <div class="company-overlay">

                            <img
                            class="logo"
                            src="https://cdn-icons-png.flaticon.com/512/5969/5969020.png">

                            <h3>Marketing Pro</h3>

                            <p>Marketing y publicidad.</p>

                            <a href="/reservar?empresa=Marketing Pro" class="btn btn-light mt-3">Reservar</a>

                        </div>

                    </div>

                </div>

                <!-- EMPRESA 5 -->

                <div class="swiper-slide">

                    <div class="company-card">

                        <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=1200">

                        <div class="company-overlay">

                            <img
                            class="logo"
                            src="https://cdn-icons-png.flaticon.com/512/5968/5968520.png">

                            <h3>Office Experts</h3>

                            <p>Administración y gestión.</p>

                            <a href="/reservar?empresa=Office Experts" class="btn btn-light mt-3">Reservar</a>

                        </div>

                    </div>

                </div>

                <!-- EMPRESA 6 -->

                <div class="swiper-slide">

                    <div class="company-card">

                        <img src="https://images.unsplash.com/photo-1556155092-490a1ba16284?q=80&w=1200">

                        <div class="company-overlay">

                            <img
                            class="logo"
                            src="https://cdn-icons-png.flaticon.com/512/5968/5968705.png">

