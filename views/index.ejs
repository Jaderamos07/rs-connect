    <!-- BOOTSTRAP -->

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- AOS -->

    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>

    <script>

        AOS.init({
            duration:1000,
            once:true
        });

    </script>

    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script>

    const swiper = new Swiper(".companiesSwiper", {

        loop:true,

        spaceBetween:30,

        autoplay:{
            delay:3000,
            disableOnInteraction:false,
        },

        pagination:{
            el:".swiper-pagination",
            clickable:true,
        },

        navigation:{
            nextEl:".swiper-button-next",
            prevEl:".swiper-button-prev",
        },

        breakpoints:{

            0:{
                slidesPerView:1,
            },

            768:{
                slidesPerView:2,
            },

            1200:{
                slidesPerView:3,
            }

        }

    });

</script>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    // Detectar si la URL tiene el parámetro registro=exito
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get('registro') === 'exito') {
        Swal.fire({
            title: '¡Bienvenido a RS Connect!',
            text: 'Tu cuenta ha sido creada exitosamente.',
            icon: 'success',
            confirmButtonColor: '#c8a96b', // Tu color dorado
            background: '#f8f5ef' // Tu color beige
        });
        // Limpiar la URL para que no salga el mensaje al recargar
        window.history.replaceState({}, document.title, "/");
    }
</script>

</body>
</html>