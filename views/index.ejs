<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>RS Connect | Inicio</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

    <!-- AOS Animations -->
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />

    <style>

        :root{
            --beige:#f8f5ef;
            --navy:#0b1c3d;
            --olive:#5c6b3d;
            --gold:#c8a96b;
            --white:#ffffff;
            --gray:#6b7280;
        }

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
        }

        body{
            font-family:'Inter',sans-serif;
            background:var(--beige);
            overflow-x:hidden;
        }

        h1,h2,h3,h4,.navbar-brand{
            font-family:'Playfair Display',serif;
        }

        /* NAVBAR */

        .navbar{
            background:rgba(11,28,61,.95)!important;
            backdrop-filter:blur(10px);
            border-bottom:1px solid rgba(255,255,255,.1);
            padding:15px 0;
        }

        .navbar-brand{
            font-size:2rem;
            color:white!important;
        }

        .gold{
            color:var(--gold);
        }

        .nav-link{
            color:white!important;
            margin-left:20px;
            transition:.3s;
        }

        .nav-link:hover{
            color:var(--gold)!important;
        }

        /* HERO */

        .hero{
            position:relative;

            background-image:
            linear-gradient(rgba(11,28,61,.85), rgba(11,28,61,.85)),
            url('https://images.unsplash.com/photo-1553877522-43269d4ea984?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D');

            background-size:cover;
            background-position:center;

            min-height:100vh;

            display:flex;
            align-items:center;

            color:white;
        }

        .hero-title{
            font-size:4.5rem;
            line-height:1.1;
            margin-bottom:30px;
        }

        .hero-text{
            font-size:1.2rem;
            color:rgba(255,255,255,.8);
            max-width:650px;
            margin-bottom:35px;
        }

        .tagline{
            color:var(--gold);
            letter-spacing:4px;
            font-size:.85rem;
            font-weight:600;
            margin-bottom:20px;
            display:block;
        }

        .btn-gold{
            background:var(--gold);
            color:white;
            padding:15px 35px;
            border:none;
            border-radius:14px;
            font-weight:600;
            transition:.3s;
            text-decoration:none;
        }

        .btn-gold:hover{
            transform:translateY(-3px);
            background:#b69153;
            color:white;
        }

        .btn-outline-custom{
            border:1px solid white;
            padding:15px 35px;
            border-radius:14px;
            color:white;
            text-decoration:none;
            transition:.3s;
        }

        .btn-outline-custom:hover{
            background:white;
            color:var(--navy);
        }

        .stats{
            display:flex;
            gap:50px;
            margin-top:60px;
        }

        .stats h3{
            color:var(--gold);
            font-size:2rem;
        }

        /* ABOUT */

        .about{
            padding:120px 0;
        }

        .about img{
            border-radius:25px;
            box-shadow:0 20px 60px rgba(0,0,0,.1);
        }

        .section-title{
            margin-bottom:60px;
        }

        .section-title h2{
            font-size:3rem;
            color:var(--navy);
        }

        .section-title p{
            color:var(--gray);
        }

        /* COMPANIES */

        .companies{
            padding:120px 0;
            background:white;
        }

        .company-card{
            position:relative;
            overflow:hidden;
            border-radius:25px;
            height:450px;
            cursor:pointer;
            box-shadow:0 20px 50px rgba(0,0,0,.08);
        }

                .swiper{
            padding-bottom:70px;
        }

        .swiper-slide{
            height:auto;
        }

        .swiper-button-next,
        .swiper-button-prev{
            color: var(--gold);
        }

        .swiper-pagination-bullet-active{
            background: var(--gold);
        }

        .company-card img{
            width:100%;
            height:100%;
            object-fit:cover;
            transition:.5s;
        }

        .company-overlay{
            position:absolute;
            inset:0;

            background:linear-gradient(
                to top,
                rgba(0,0,0,.9),
                rgba(0,0,0,.1)
            );

            display:flex;
            flex-direction:column;
            justify-content:end;

            padding:30px;

            opacity:0;
            transition:.4s;
        }

        .company-card:hover .company-overlay{
            opacity:1;
        }

        .company-card:hover img{
            transform:scale(1.1);
        }

        .company-overlay h3{
            color:white;
            margin-bottom:10px;
        }

        .company-overlay p{
            color:rgba(255,255,255,.8);
        }

        

        .logo{
            width:80px!important;
            height:80px!important;
            object-fit:contain!important;
            margin-bottom:20px;
            background:white;
            padding:10px;
            border-radius:15px;
        }

        /* CTA */

        .cta{
            padding:120px 0;
            background:linear-gradient(to right, #081120, #0b1c3d);
            color:white;
            text-align:center;
        }

        .cta h2{
            font-size:3rem;
            margin-bottom:25px;
        }

        /* FOOTER */

        footer{
            background:#050b16;
            color:rgba(255,255,255,.7);
            padding:70px 0 20px;
        }

        footer h5{
            color:white;
            margin-bottom:20px;
        }

        footer a{
            color:rgba(255,255,255,.6);
            text-decoration:none;
            transition:.3s;
        }

        footer a:hover{
            color:var(--gold);
        }

        .footer-bottom{
            border-top:1px solid rgba(255,255,255,.1);
            margin-top:50px;
            padding-top:20px;
            text-align:center;
        }

        /* RESPONSIVE */

        @media(max-width:768px){

            .hero-title{
                font-size:3rem;
            }

            .stats{
                flex-direction:column;
                gap:20px;
            }

        }

    </style>
</head>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"/>

<body>

    <!-- NAVBAR -->

    <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
