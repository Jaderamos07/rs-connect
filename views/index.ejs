                        </div>

                    </div>

                </div>

            </div>

            <!-- BOTONES -->

            <div class="swiper-button-next"></div>
            <div class="swiper-button-prev"></div>

            <!-- PAGINATION -->

            <div class="swiper-pagination"></div>

        </div>

    </div>

</section>

    <!-- CTA -->

    <section class="cta">

        <div class="container" data-aos="zoom-in">

            <h2>
                Únete al ecosistema RS Connect
            </h2>

            <p class="mb-5">
                Empresas y clientes conectados en una sola plataforma moderna.
            </p>

            <a href="/usuarios/registro" class="btn-gold">
                Registrarse Ahora
            </a>

        </div>

    </section>

    <!-- FOOTER -->

    <footer>

        <div class="container">

            <div class="row">

                <div class="col-lg-4 mb-5">

                    <h5>RS CONNECT</h5>

                    <p>
                        Plataforma moderna para reservas,
                        servicios y gestión empresarial premium.
                    </p>

                </div>

                <div class="col-lg-2 mb-5">

                    <h5>Empresa</h5>

                    <ul class="list-unstyled">

                        <li class="mb-2">
                            <a href="#">Nosotros</a>
                        </li>

                        <li class="mb-2">
                            <a href="#">Servicios</a>
                        </li>

                        <li class="mb-2">
                            <a href="#">Contacto</a>
                        </li>

                    </ul>

                </div>

                <div class="col-lg-3 mb-5">

                    <h5>Soporte</h5>

                    <ul class="list-unstyled">

                        <li class="mb-2">
                            <a href="#">Privacidad</a>
                        </li>

                        <li class="mb-2">
                            <a href="#">Términos</a>
                        </li>

                        <li class="mb-2">
                            <a href="#">Ayuda</a>
                        </li>

                    </ul>

                </div>

                <div class="col-lg-3">

                    <h5>Newsletter</h5>

                    <div class="input-group mt-3">

                        <input
                        type="email"
                        class="form-control"
