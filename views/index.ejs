                        <div>
                            <h3>100%</h3>
                            <p>Seguridad</p>
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </section>

    <!-- ABOUT -->

    <section class="about" id="nosotros">

        <div class="container">

            <div class="row align-items-center">

                <div class="col-lg-6 mb-5" data-aos="fade-right">

                    <img
                    src="https://images.unsplash.com/photo-1603201667230-bd139210db18?q=80&w=1188&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
                    class="img-fluid">

                </div>

                <div class="col-lg-6" data-aos="fade-left">

                    <div class="section-title">

                        <h2>
                            Sobre RS Connect
                        </h2>

                        <p>
                            Una plataforma moderna para gestionar servicios,
                            reservas y conexiones empresariales.
                        </p>

                    </div>

                    <p class="mb-4">
                        RS Connect funciona como un conglomerado digital donde
